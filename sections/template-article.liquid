<h1>{{article.title}}</h1>
<small>{{article.author}}</small>
<time datetime="{{article.published_at | date: '%Y-%m-%d'}}">{{article.published_at | date: '%B %d, %Y'}}</time>
<img src="{{article.image | img_url: 'large'}}" loading="lazy" alt="{{article.title}}" width="600" height="400"/>
<div class="m-6">{{article.content}}</div>