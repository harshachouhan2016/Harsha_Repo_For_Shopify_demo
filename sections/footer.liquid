<footer class="bg-theme-surface border-t border-theme mt-4">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div {{ block.shopify_attributes }}>
            <h4 class="text-sm font-semibold uppercase tracking-wide text-gray-900">{{ block.settings.heading }}</h4>
            <ul class="mt-4 space-y-2">
              {% assign items = block.settings.links | newline_to_br | split: '<br />' %}
              {% for item in items %}
                {% assign parts = item | strip | split: '|' %}
                {% if parts.size > 0 and parts.first != blank %}
                  <li><a href="{{ parts.last | strip }}" class="text-sm text-theme-muted hover:text-theme-primary">{{ parts.first | strip }}</a></li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="mt-12 pt-8 border-t border-theme flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-lg font-bold text-gray-900">{{ shop.name }}</p>
      <p class="text-sm text-theme-muted">{{ section.settings.copyright }}</p>
    </div>
    <p class="mt-3 text-xs text-theme-muted text-center sm:text-left">{{ section.settings.disclaimer }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 — All rights reserved." },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer", "default": "Demo store. Products and imagery are placeholders for layout purposes only." }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link Column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "textarea", "id": "links", "label": "Links (one per line: Label | /url)", "default": "Best Sellers | /collections/all\nNew Arrivals | /collections/all\nLip | /collections/all\nCheek | /collections/all" }
      ]
    }
  ],
  "presets": [
    { "name": "Footer" }
  ]
}
{% endschema %}
