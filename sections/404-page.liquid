<h1>{{ section.settings.title }}</h1>
<p>{{ section.settings.subtitle_text }}</p>


{% schema %}
{
    "name": "Template 404",
    "settings": [
        {
        "type": "text",
        "id": "title",
        "default": "404 Page",
        "label": "404 heading title"

       },
        {
        "type": "text",
        "id": "subtitle_text",
        "default": "The page you are looking for does not exist.",
        "label": "404 subtitle text"

       }

]
}
{% endschema %}