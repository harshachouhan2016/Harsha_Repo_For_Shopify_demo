{% comment %}
  Rare Beauty–inspired homepage.
  All products/images here are DUMMY placeholders defined via section settings & blocks,
  so the page renders standalone without a connected store. Swap the placehold.co URLs
  and block content for real assets / collections when wiring up a live store.
{% endcomment %}

{%- assign hero_image = section.settings.hero_image_url | default: 'pexels-michael-steinberg-95604-346553.jpg' -%}
{%- if hero_image contains 'http' -%}
  {%- assign hero_src = hero_image -%}
{%- else -%}
  {%- assign hero_src = hero_image | asset_url -%}
{%- endif -%}

<!-- ============================ HERO ============================ -->
<section class="relative isolate overflow-hidden">
  <img src="{{ hero_src }}" alt="{{ section.settings.hero_heading | escape }}"
       class="absolute inset-0 -z-10 h-full w-full object-cover">
  <div class="absolute inset-0 -z-10 bg-black/30"></div>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-28 sm:py-40 text-center">
    <p class="text-sm uppercase tracking-[0.3em] text-white/90 mb-4">{{ section.settings.hero_eyebrow }}</p>
    <h2 class="text-white text-4xl sm:text-6xl font-bold max-w-3xl mx-auto leading-tight">
      {{ section.settings.hero_heading }}
    </h2>
    <p class="text-white/90 text-lg mt-5 max-w-xl mx-auto">{{ section.settings.hero_subheading }}</p>
    <div class="mt-9 flex flex-wrap gap-4 justify-center">
      <a href="{{ section.settings.hero_cta_link }}"
         class="inline-block rounded-full px-8 py-3 text-base font-medium text-white bg-theme-primary hover:opacity-90 transition">
        {{ section.settings.hero_cta_label }}
      </a>
      <a href="{{ section.settings.hero_cta2_link }}"
         class="inline-block rounded-full px-8 py-3 text-base font-medium text-gray-900 bg-white hover:bg-neutral-100 transition">
        {{ section.settings.hero_cta2_label }}
      </a>
    </div>
  </div>
</section>

<!-- ====================== VALUE STRIP ========================== -->
<div class="bg-theme-secondary">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-4 grid grid-cols-2 md:grid-cols-4 gap-4 text-center text-sm">
    <div>✦ Cruelty-Free &amp; Vegan</div>
    <div>✦ Clean Ingredients</div>
    <div>✦ Free Shipping over $50</div>
    <div>✦ 1% Supports Mental Health</div>
  </div>
</div>

<!-- ====================== CATEGORY TILES ======================= -->
<section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
  <h3 class="text-3xl font-bold text-center mb-10">Shop by Category</h3>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a href="{{ block.settings.link }}" class="group block" {{ block.shopify_attributes }}>
          <div class="overflow-hidden rounded-2xl bg-theme-secondary aspect-square">
            <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}"
                 class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
          </div>
          <p class="mt-3 text-center text-base font-medium text-gray-900">{{ block.settings.title }}</p>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- ====================== BEST SELLERS ========================= -->
<section class="bg-theme-secondary/40">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
    <div class="flex items-end justify-between mb-10">
      <h3 class="text-3xl font-bold">Best Sellers</h3>
      <a href="/collections/all" class="text-base font-medium text-theme-primary hover:underline">View all →</a>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          <div class="group bg-theme-surface rounded-2xl overflow-hidden border border-theme" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="block overflow-hidden bg-theme-secondary aspect-square">
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}"
                   class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
            </a>
            <div class="p-4">
              <p class="text-xs uppercase tracking-wide text-theme-muted">{{ block.settings.category }}</p>
              <a href="{{ block.settings.link }}">
                <h4 class="mt-1 text-base font-medium text-gray-900">{{ block.settings.title }}</h4>
              </a>
              <div class="mt-1 text-sm text-theme-primary">★★★★★ <span class="text-theme-muted">({{ block.settings.reviews }})</span></div>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-base font-semibold text-gray-900">{{ block.settings.price }}</span>
                <button type="button"
                        class="rounded-full px-4 py-1.5 text-sm font-medium text-white bg-theme-primary hover:opacity-90 transition">
                  Add to Bag
                </button>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- ====================== PRODUCT SPOTLIGHT ==================== -->
<section class="mx-auto max-w-7xl px-4 sm:px-6 py-20">
  <div class="grid lg:grid-cols-2 gap-10 items-center">
    <div class="overflow-hidden rounded-3xl bg-theme-secondary aspect-[4/3]">
      <img src="{{ section.settings.spotlight_image_url }}" alt="{{ section.settings.spotlight_heading | escape }}"
           class="h-full w-full object-cover">
    </div>
    <div>
      <p class="text-sm uppercase tracking-[0.3em] text-theme-primary mb-3">{{ section.settings.spotlight_eyebrow }}</p>
      <h3 class="text-4xl font-bold leading-tight">{{ section.settings.spotlight_heading }}</h3>
      <p class="mt-5 text-lg text-theme-muted">{{ section.settings.spotlight_body }}</p>
      <a href="{{ section.settings.spotlight_link }}"
         class="mt-8 inline-block rounded-full px-8 py-3 text-base font-medium text-white bg-theme-primary hover:opacity-90 transition">
        {{ section.settings.spotlight_cta }}
      </a>
    </div>
  </div>
</section>

<!-- ====================== BRAND MISSION ======================= -->
<section class="bg-theme-primary">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h3 class="text-white text-3xl sm:text-4xl font-bold">{{ section.settings.mission_heading }}</h3>
    <p class="text-white/90 text-lg mt-6">{{ section.settings.mission_body }}</p>
    <a href="{{ section.settings.mission_link }}"
       class="mt-8 inline-block rounded-full px-8 py-3 text-base font-medium text-gray-900 bg-white hover:bg-neutral-100 transition">
      {{ section.settings.mission_cta }}
    </a>
  </div>
</section>

<!-- ====================== REVIEWS ============================== -->
<section class="mx-auto max-w-7xl px-4 sm:px-6 py-16">
  <h3 class="text-3xl font-bold text-center mb-10">Loved by Our Community</h3>
  <div class="grid md:grid-cols-3 gap-6">
    {% for block in section.blocks %}
      {% if block.type == 'review' %}
        <figure class="bg-theme-surface rounded-2xl border border-theme p-6" {{ block.shopify_attributes }}>
          <div class="text-theme-primary mb-3">★★★★★</div>
          <blockquote class="text-base text-theme-muted">“{{ block.settings.quote }}”</blockquote>
          <figcaption class="mt-4 text-sm font-medium text-gray-900">— {{ block.settings.author }}</figcaption>
        </figure>
      {% endif %}
    {% endfor %}
  </div>
</section>

<!-- ====================== NEWSLETTER ========================== -->
<section class="bg-theme-secondary">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 py-16 text-center">
    <h3 class="text-3xl font-bold">{{ section.settings.newsletter_heading }}</h3>
    <p class="mt-3 text-theme-muted">{{ section.settings.newsletter_body }}</p>
    <form class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
      <input type="email" required placeholder="Enter your email"
             class="flex-1 rounded-full border border-theme bg-white px-5 py-3 text-base outline-none focus:border-theme-primary">
      <button type="submit"
              class="rounded-full px-8 py-3 text-base font-medium text-white bg-theme-primary hover:opacity-90 transition">
        Subscribe
      </button>
    </form>
  </div>
</section>

{% schema %}
